# AlphaShop API 凭证配置示例
#
# 使用方法：
# 1. 复制本文件为 .env
# 2. 填入你的真实凭证
# 3. 运行: source .env
# 4. 然后执行 skill 命令

# AlphaShop API 访问密钥
export ALPHASHOP_ACCESS_KEY='your-access-key-here'

# AlphaShop API 密钥
export ALPHASHOP_SECRET_KEY='your-secret-key-here'

# 使用示例:
# python3 scripts/selection.py report --keyword "phone" --platform "amazon" --country "US"
